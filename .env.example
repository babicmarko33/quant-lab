# =============================================================================
# QUANT-LAB ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your API keys
# NEVER commit .env to version control
# =============================================================================

# --- Market Data Providers ---

# Alpaca Markets (free paper trading + market data)
# Sign up: https://app.alpaca.markets/signup
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets  # Use paper trading

# Alpha Vantage (free tier: 25 requests/day)
# Sign up: https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY=your_alphavantage_key_here

# Polygon.io (free tier: 5 requests/min, delayed data)
# Sign up: https://polygon.io/dashboard/signup
POLYGON_API_KEY=your_polygon_key_here

# yfinance — no key needed (primary free source)

# --- Vibe-Trading (Research Tool) ---
# Install: pip install vibe-trading-ai
# Provider options: openrouter, deepseek, groq, ollama
LANGCHAIN_PROVIDER=deepseek
DEEPSEEK_API_KEY=your_deepseek_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
LANGCHAIN_MODEL_NAME=deepseek-chat

# --- Application Settings ---
DATA_CACHE_DIR=data/cache
LOG_LEVEL=INFO
DEFAULT_BENCHMARK=SPY
BACKTEST_COMMISSION_BPS=10  # 10 basis points round-trip
